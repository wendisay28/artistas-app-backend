{
  "name": "buscartpro-backend",
  "version": "1.0.0",
  "description": "Backend for BuscartPro application",
  "main": "dist/backend/src/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "rimraf dist && tsc",
    "watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --detectOpenHandles --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage",
    "db:init": "NODE_OPTIONS='--loader ts-node/esm' scripts/init-db.ts",
    "db:migrate": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:add-indices": "tsx scripts/add-indices.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:artists": "tsx scripts/seed-artists.ts",
    "migrate:custom": "NODE_OPTIONS='--loader ts-node/esm' scripts/migrate.ts",
    "migrate:explorer": "tsx src/scripts/run-explorer-migration-pg.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.53.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.18",
    "@types/express-validator": "^2.20.33",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^1.4.13",
    "@types/nanoid": "^2.1.0",
    "@types/pdfkit": "^0.17.4",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.43.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.4.0",
    "fs-extra": "^11.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.0",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.3",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@faker-js/faker": "^9.9.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.22",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.1",
    "jest": "^30.1.3",
    "mysql2": "^3.14.1",
    "nodemon": "^3.0.2",
    "rimraf": "^5.0.7",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
