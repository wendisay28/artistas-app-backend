# Configuración del servidor
PORT=5001
NODE_ENV=development

# Base de datos Neon (PostgreSQL)
# Formato: postgresql://usuario:contraseña@endpoint.neon.tech/nombre_bd?sslmode=require
NEON_DATABASE_URL=postgresql://usuario:contraseña@ep-nombre-proyecto.us-east-2.aws.neon.tech/buscartpro?sslmode=require

# Seguridad
JWT_SECRET=tu-jwt-secreto-muy-seguro
JWT_EXPIRATION=24h

# CORS - URLs permitidas (separadas por comas)
FRONTEND_URL=http://localhost:5173
# Permitir requests sin origin en desarrollo (solo para testing con Postman/Insomnia)
# NUNCA habilitar en producción
ALLOW_NO_ORIGIN=false

# Firebase Admin (para autenticación)
# Obt estas credenciales desde Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# Nota: Mantén los caracteres \n en la clave privada
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_DE_FIREBASE\n-----END PRIVATE KEY-----\n

# Configuración de Supabase (para almacenamiento)
# Obtén estos valores desde la configuración de tu proyecto en Supabase
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=tu-clave-anon-supabase
SUPABASE_SERVICE_ROLE_KEY=tu-clave-rol-servicio-supabase
SUPABASE_STORAGE_BUCKET=nombre-del-bucket
