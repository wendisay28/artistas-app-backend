# Configuración del servidor
PORT=5001
NODE_ENV=development

# Base de datos Neon (PostgreSQL)
# Formato: postgresql://usuario:contraseña@endpoint.neon.tech/nombre_bd?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/buscartpro?sslmode=disable

# Seguridad
JWT_SECRET=tu-jwt-secreto-muy-seguro-cambiar-en-produccion
JWT_EXPIRATION=24h

# CORS - URLs permitidas (separadas por comas)
FRONTEND_URL=http://localhost:8081
# Permitir requests sin origin en desarrollo (solo para testing con Postman/Insomnia)
# NUNCA habilitar en producción
ALLOW_NO_ORIGIN=true

# Firebase Admin (para autenticación)
# Obtén estas credenciales desde Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_PROJECT_ID=buscartpro-ecf88
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@buscartpro-ecf88.iam.gserviceaccount.com
# Nota: Mantén los caracteres \n en la clave privada
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC5V7V\nTU_CLAVE_PRIVADA_DE_EJEMPLO_CAMBIAR_ESTA\n-----END PRIVATE KEY-----\n

# Configuración de Supabase (para almacenamiento)
