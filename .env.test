# Configuración de prueba
NODE_ENV=test
PORT=3001

# Configuración de la base de datos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buscartpro_test

# Configuración de Firebase
FIREBASE_PROJECT_ID=buscartpro-test
FIREBASE_CLIENT_EMAIL=test@buscartpro.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=test-key-123

# Configuración de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://test.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=test-anon-key
SUPABASE_URL=https://test.supabase.co
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
SUPABASE_JWT_SECRET=test-jwt-secret

# Configuración de JWT
JWT_SECRET=test-secret-key-123
JWT_EXPIRES_IN=1h

# Configuración de CORS
FRONTEND_URL=http://localhost:3000

# Configuración de correo electrónico
SMTP_HOST=smtp.test.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=test-password
SMTP_FROM=test@buscartpro.com
